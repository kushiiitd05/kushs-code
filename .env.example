# Kush's Code — Configuration
CLAW_PROVIDER=ollama

# Ollama LOCAL (default)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_MODELS=qwen2.5-coder:1.5b,qwen2.5-coder:7b,qwen3:latest
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=2048
OLLAMA_KEEP_ALIVE=30m
ANTHROPIC_COMPAT_PORT=8792

# Ollama A100 GPU Server (uncomment + connect VPN)
# OLLAMA_BASE_URL=http://192.168.3.20:11434
# OLLAMA_MODEL=qwen2.5-coder:32b
# OLLAMA_NUM_CTX=16384

# Anthropic fallback (kush-cloud only)
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
